insertInvite:
INSERT INTO Invite(
  created_at,
  created_by,
  version,
  code
)
VALUES (
  :created_at,
  :created_by,
  :version,
  :code
);

claimInvite:
UPDATE Invite
SET
  version = :new_version,
  claimed_at = :claimed_at,
  claimed_by = :claimed_by
WHERE
  version = :expected_version AND
  id = :id;

findInvitesByClaimedBy:
SELECT * FROM Invite WHERE claimed_by = :claimed_by LIMIT :limit;

findInvitesByCode:
SELECT * FROM Invite WHERE code = :code;
