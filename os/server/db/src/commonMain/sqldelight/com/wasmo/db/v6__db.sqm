import com.wasmo.identifiers.AccountId;
import com.wasmo.identifiers.InviteId;
import kotlin.time.Instant;

CREATE TABLE Invite (
  id BIGINT AS InviteId GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  created_at TIMESTAMPTZ AS Instant NOT NULL,
  created_by BIGINT AS AccountId NOT NULL,
  version INTEGER NOT NULL,
  code VARCHAR(25) UNIQUE NOT NULL,
  claimed_at TIMESTAMPTZ AS Instant NULL,
  claimed_by BIGINT AS AccountId NULL
);

CREATE INDEX InviteByClaimedById ON Invite (
  claimed_by
);
