import com.wasmo.journal.db.AttachmentId;
import com.wasmo.journal.db.EntryId;
import kotlin.time.Instant;

CREATE TABLE Attachment (
  id BIGINT AS AttachmentId GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  entry_token VARCHAR(25) NOT NULL,
  attachment_token VARCHAR(25) UNIQUE NOT NULL,
  posted_at VARCHAR(255) AS Instant NOT NULL
);

CREATE INDEX AttachmentEntryToken ON Attachment (
  entry_token
);
