import com.wasmo.journal.api.Visibility;
import com.wasmo.journal.db.EntryId;
import kotlin.time.Instant;

CREATE TABLE Entry (
  id BIGINT AS EntryId GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
  token VARCHAR(25) UNIQUE NOT NULL,
  version BIGINT NOT NULL,
  visibility VARCHAR(255) AS Visibility NOT NULL,
  date VARCHAR(255) AS Instant NOT NULL,
  slug VARCHAR(255) UNIQUE NOT NULL,
  title VARCHAR(65535) NOT NULL,
  body VARCHAR(255) NOT NULL
);
