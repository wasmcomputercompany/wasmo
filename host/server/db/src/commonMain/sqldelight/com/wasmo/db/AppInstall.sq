insertAppInstall:
INSERT INTO AppInstall(
  computer_id,
  slug,
  version,
  manifest_url,
  launcher_label,
  install_scheduled_at
)
VALUES (
  :computer_id,
  :slug,
  :version,
  :manifest_url,
  :launcher_label,
  :install_scheduled_at
) RETURNING id;

selectAppInstallsByComputerId:
SELECT * FROM AppInstall
WHERE computer_id = :computer_id
ORDER BY id
LIMIT :limit;

selectAppInstallById:
SELECT * FROM AppInstall
WHERE id = :id;

updateAppInstallSetInstallCompletedAt:
UPDATE AppInstall
SET
  version = :new_version,
  install_completed_at = :install_completed_at
WHERE
  version = :expected_version AND
  id = :id;

updateAppInstallSetInstallIncompleteReason:
UPDATE AppInstall
SET
  version = :new_version,
  install_incomplete_reason = :install_incomplete_reason
WHERE
  version = :expected_version AND
  id = :id;
